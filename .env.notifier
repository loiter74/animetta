# ── Anima Notifier Configuration ──
# Only NOTIFIER_* and ALERT_* variables.
# Kept separate from .env to avoid exposing LLM API keys to the Notifier container.

# Discord webhook URL (copy from Discord channel settings → Integrations → Webhooks)
NOTIFIER_DISCORD_WEBHOOK_URL=

# Feishu webhook URL (copy from Feishu group bot)
NOTIFIER_FEISHU_WEBHOOK_URL=
# Feishu sign secret (optional, leave empty if not configured on the bot)
NOTIFIER_FEISHU_SIGN_SECRET=

# Email (SMTP)
NOTIFIER_SMTP_HOST=smtp.gmail.com
NOTIFIER_SMTP_PORT=587
NOTIFIER_SMTP_USER=
NOTIFIER_SMTP_PASSWORD=
NOTIFIER_EMAIL_FROM=alerts@anima.local
NOTIFIER_EMAIL_TO=admin@example.com
