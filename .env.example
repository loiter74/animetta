# ── Animetta Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# === LLM Providers ===

# GLM (Zhipu AI) — required if services.agent = glm
GLM_API_KEY=your_glm_api_key_here

# OpenAI-compatible (DeepSeek, OpenAI, etc.)
# Used when services.agent = deepseek or services.agent = openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# === Service Selection ===

# Primary LLM: deepseek, glm, openai, ollama, local_lora
ANIMETTA_LLM=deepseek

# Text-to-Speech: vibe_voice, edge, glm, openai, chattts, mock
ANIMETTA_TTS=vibe_voice

# Speech Recognition: faster_whisper, glm, openai, funasr, mock
ANIMETTA_ASR=faster_whisper

# Voice Activity Detection: silero, mock
ANIMETTA_VAD=silero

# === Server ===

ANIMETTA_HOST=0.0.0.0
ANIMETTA_PORT=12394
ANIMETTA_LOG_LEVEL=INFO

# === Paths ===

# Project root — auto-detected, usually no need to set
# ANIMETTA_PROJECT_ROOT=/path/to/Anima

# Base model directory for local models
ANIMETTA_BASE_MODEL_PATH=./models

# LoRA adapter path
ANIMETTA_LORA_PATH=./loras

# === GPT-SoVITS (local TTS inference) — required for tts: gpt_sovits* ===
# GPT_SOVITS_PATH=/path/to/GPT-SoVITS-v2pro
# GPT_SOVITS_PYTHON=python

# === RVC (Retrieval-based Voice Conversion) — required for singing module ===
# RVC_PATH=/path/to/RVC

# === Demucs (Music Source Separation) — optional ===
# DEMUCS_CONFIG_PATH=/path/to/config_vocals_mel_band_roformer.yaml

# === LangFuse (Observability) — optional ===

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# === Alerting (Discord / Feishu / Email) — optional ===
# These are for the Notifier Docker sidecar. Store them in .env.notifier.
# See observability/ section in README for setup instructions.

# Discord webhook URL — copy from channel Settings → Integrations → Webhooks
NOTIFIER_DISCORD_WEBHOOK_URL=

# Feishu webhook URL — copy from group Custom Bot webhook
NOTIFIER_FEISHU_WEBHOOK_URL=
# Feishu sign secret (optional — set on the bot for HMAC-SHA256 auth)
NOTIFIER_FEISHU_SIGN_SECRET=

# Email SMTP settings (example: Gmail)
NOTIFIER_SMTP_HOST=smtp.gmail.com
NOTIFIER_SMTP_PORT=587
NOTIFIER_SMTP_USER=
NOTIFIER_SMTP_PASSWORD=
NOTIFIER_EMAIL_FROM=alerts@animetta.local
NOTIFIER_EMAIL_TO=admin@example.com
