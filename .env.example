# ── Anima Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# === LLM Providers ===

# GLM (Zhipu AI) — required if services.agent = glm
GLM_API_KEY=your_glm_api_key_here

# OpenAI-compatible (DeepSeek, OpenAI, etc.)
# Used when services.agent = deepseek or services.agent = openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# === Service Selection ===

# Primary LLM: deepseek, glm, openai, ollama, local_lora
ANIMA_LLM=deepseek

# Text-to-Speech: vibe_voice, edge, glm, openai, chattts, mock
ANIMA_TTS=vibe_voice

# Speech Recognition: faster_whisper, glm, openai, funasr, mock
ANIMA_ASR=faster_whisper

# Voice Activity Detection: silero, mock
ANIMA_VAD=silero

# === Server ===

ANIMA_HOST=0.0.0.0
ANIMA_PORT=12394
ANIMA_LOG_LEVEL=INFO

# === Paths ===

# Base model directory for local models
ANIMA_BASE_MODEL_PATH=./models

# LoRA adapter path
ANIMA_LORA_PATH=./loras

# === LangFuse (Observability) — optional ===

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
