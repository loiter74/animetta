{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["renderer/shared/*"],
      "@live2d/*": ["renderer/live2d/*"],
      "@chat/*": ["renderer/chat/*"]
    }
  },
  "include": [
    "main/**/*",
    "renderer/**/*",
    "preload/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
