# Memory System Configuration
# 基于 OpenClaw 架构的新版记忆系统配置

memory:
  enabled: true

  # 工作目录 - 所有记忆文件的存储位置
  # 使用项目目录下的 memory_db/
  workspace_dir: "./memory_db"

  # 短期记忆（内存缓存）
  short_term:
    max_turns: 20  # 内存中保留的最大轮数

  # 分块配置
  chunk:
    target_tokens: 400  # 每块目标 token 数
    overlap_tokens: 80  # 相邻块重叠 token 数
    chars_per_token: 2.0  # 中文字符/token 比

  # 搜索配置
  search:
    vector_weight: 0.7  # 向量得分权重
    keyword_weight: 0.3  # 关键词 (BM25) 得分权重
    default_max_results: 10

  # Embedding 模型配置
  # 注意：需要从 huggingface.co 下载模型，首次使用需要网络
  embedding:
    model_name: "BAAI/bge-small-zh-v1.5"  # 中文推荐模型
    # model_name: "sentence-transformers/all-MiniLM-L6-v2"  # 英文模型

  # 上下文压缩前 flush 配置
  flush:
    enabled: true
    soft_threshold_tokens: 4000
    reserve_tokens_floor: 20000

  # ── 定时调度器 (Scheduler) ─────────────────────────────────
  scheduler:
    enabled: true
    tasks:
      consolidate_conversations:
        interval: 3600       # 1 小时
        timeout: 120
      extract_patterns:
        interval: 86400      # 24 小时
        timeout: 300
      generate_meme_candidates:
        interval: 21600      # 6 小时
        timeout: 120
      maintain_meme_pool:
        interval: 3600       # 1 小时
        timeout: 30
      prune_learning_logs:
        interval: 86400      # 24 小时
        timeout: 60

  # ── 模糊记忆 (Fuzzy Memory) ────────────────────────────────
  fuzzy_memory:
    enabled: true
    granularity_weights:
      fact: 0.3
      persona: 0.2
      event: 0.5
    consolidation:
      turns_per_lightweight: 1     # 每轮对话后轻量整理
      turns_per_deep: 10            # 每 N 轮深度整理
      deep_interval_minutes: 60     # 深度整理最大间隔
    injection:
      tier1_max_items: 3            # 上下文层最大条数
      tier2_max_items: 5            # 支撑层最大条数
      tier3_max_items: 3            # 精确层最大条数
      escalation_thresholds:
        tier2_depth: 2              # 追问 2 次升级到支撑层
        tier3_depth: 4              # 追问 4 次升级到精确层

  # ── 梗管理 (Meme Pool) ────────────────────────────────────
  meme_pool:
    enabled: true
    max_active: 10
    ai_source_ratio: 0.8           # AI 发现占比
    user_source_ratio: 0.2         # 用户配置占比
    scoring:
      default_base_score: 0.7
      user_meme_bonus: 0.1         # 用户配置梗的初始加成
      resurrection_bonus: 0.1      # 每次复活的分数加成
      resurrection_max_bonuses: 3  # 最大复活次数（之后锁定）
    time_decay:
      k: 0.5                       # 衰减速率
      t_half_days: 7               # 半衰期（天）
      resurrection_threshold: 0.6  # 复活阈值

  # ── 学习模块 (PeriodicLearner) ────────────────────────────
  learner:
    enabled: true
    llm_temperature: 0.3           # 学习用 LLM 温度（较低 = 更确定）
    log_retention_days: 90         # 学习日志保留天数
    patterns_per_run: 5            # 每次提取的模式数上限
    meme_candidates_per_run: 3     # 每次生成的梗候选数上限

# 记忆文件结构说明:
# ─────────────────────────────────────────
# memory_db/
# ├── MEMORY.md           # 长期记忆（重要对话摘要）
# ├── memory.sqlite       # SQLite + FTS5 索引
# ├── chroma_db/          # Chroma 向量索引
# └── memory/
#     ├── 2026-03-13.md   # 每日对话日志
#     └── ...
#
# 日志格式 (memory/YYYY-MM-DD.md):
# ─────────────────────────────────────────
# ## 14:30
# **User**: 你好
# **AI**: 你好！有什么可以帮你的吗？
# *Emotions: happy, friendly*
#
# 长期记忆格式 (MEMORY.md):
# ─────────────────────────────────────────
# # Long-term Memory
#
# - [2026-03-13] 用户喜欢用 Python 编程...
# - [2026-03-12] 用户提到最近喜欢吃寿司...
#
