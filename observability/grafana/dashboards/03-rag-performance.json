{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Retrieval Latency (p50/p95) by Strategy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(anima_rag_retrieval_duration_seconds_bucket[5m])) by (le, strategy))",
          "legendFormat": "{{strategy}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(anima_rag_retrieval_duration_seconds_bucket[5m])) by (le, strategy))",
          "legendFormat": "{{strategy}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Chunks Retrieved Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(anima_rag_chunks_retrieved_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Top Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(anima_rag_top_score_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Average Retrieval Duration (by Strategy)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(anima_rag_retrieval_duration_seconds_sum[5m])) by (strategy) / sum(rate(anima_rag_retrieval_duration_seconds_count[5m])) by (strategy)",
          "legendFormat": "{{strategy}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "RAG Latency over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(anima_rag_retrieval_duration_seconds_bucket[5m])) by (le, strategy))",
          "legendFormat": "{{strategy}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["anima", "rag"],
  "templating": {
    "list": [
      {
        "name": "strategy",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(anima_rag_retrieval_duration_seconds_count, strategy)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "Anima - RAG Performance",
  "uid": "anima-rag",
  "version": 1
}
